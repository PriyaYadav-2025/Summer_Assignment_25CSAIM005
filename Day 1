#include<stdio.h>
int main()
{
    int i ,n,sum=0;
    printf("Enter the number");
    scanf("%d",&n);
    for(i=0;i<=n;i++)
      sum+=i;
    printf("sum of first %d natural numbers is %d",n,sum);
    return 0;
}
  
#include<stdio.h>
int main()
{
    int n;
    printf("Enter any number");
    scanf("%d",&n);
    for(i=1;i<=10;i++)
      printf("%d*%d=%d\n",n,i,n*i);
    return 0;
}


